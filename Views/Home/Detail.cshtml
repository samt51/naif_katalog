@model naif_katalog.Models.Product
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    var apiAddress = Configuration["ApiAdress"] ?? "https://apib2b.naifjewellery.com/";
    if (apiAddress.EndsWith("/")) apiAddress = apiAddress.Substring(0, apiAddress.Length - 1);
    ViewData["Title"] = Model.Name + " - Detay";
    bool isLoggedIn = User.Identity?.IsAuthenticated == true;
    string adminWhatsAppPhone = "905551234567"; // Replace with real admin phone
    decimal mockPrice = Model.CalculatedPrice > 0 ? Model.CalculatedPrice : 150m;
}

<style>
    .product-detail-container {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.05);
        overflow: hidden;
        margin-top: 40px;
        margin-bottom: 40px;
    }
    .detail-image-gallery {
        background: #fff;
        padding: 40px;
        position: relative;
    }
    .gallery-sticky-wrapper {
        position: sticky;
        top: 120px;
        display: flex;
        flex-direction: column;
        width: 100%;
        height: auto;
    }
    .main-image {
        width: 100%;
        transition: transform 0.3s ease;
    }
    .main-image:hover {
        transform: scale(1.02);
    }
    .thumbnail-container {
        display: flex;
        gap: 15px;
        margin-top: 25px;
        overflow-x: auto;
        padding-bottom: 10px;
    }
    .thumbnail {
        width: 80px;
        height: 80px;
        border-radius: 8px;
        object-fit: cover;
        cursor: pointer;
        border: 2px solid transparent;
        transition: all 0.2s;
    }
    .thumbnail:hover, .thumbnail.active {
        border-color: #10b981;
        opacity: 0.8;
    }
    .detail-info {
        padding: 40px;
        background: #fff;
    }
    .badge-category {
        background: #e2e8f0;
        color: #475569;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
        display: inline-block;
        margin-bottom: 15px;
    }
    .product-title {
        font-size: 32px;
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 10px;
        letter-spacing: -0.5px;
    }
    .product-code {
        color: #64748b;
        font-size: 16px;
        margin-bottom: 30px;
    }
    .price-tag {
        font-size: 36px;
        font-weight: 800;
        color: #10b981;
        margin-bottom: 30px;
    }
    .specs-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 40px;
    }
    .spec-item {
        background: #f8fafc;
        padding: 15px 20px;
        border-radius: 12px;
        display: flex;
        flex-direction: column;
    }
    .spec-label {
        font-size: 12px;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 4px;
    }
    .spec-value {
        font-size: 16px;
        font-weight: 700;
        color: #1e293b;
    }
    .action-button {
        padding: 16px 32px;
        font-size: 18px;
        font-weight: 600;
        border-radius: 50px;
        transition: all 0.3s;
        text-transform: uppercase;
        letter-spacing: 1px;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }
    .action-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }
</style>

<div class="container">
    <!-- Back Button -->
    <a href="/Home/Index" class="btn btn-light rounded-pill mt-4 mb-2" style="font-weight: 600; padding: 10px 20px;">
        <i class="fas fa-arrow-left me-2"></i> Kataloğa Dön
    </a>

    <div class="product-detail-container row g-0">
        <!-- Image Gallery -->
        <div class="col-lg-6 detail-image-gallery border-end">
            <div class="gallery-sticky-wrapper">
                @if (Model.Images.Count > 0)
                {
                    <div class="img-magnifier-container" id="imageContainer" style="overflow:hidden; border-radius: 16px; cursor:crosshair; width:100%; aspect-ratio: 1/1.1; max-height: 800px; box-shadow: 0 8px 30px rgba(0,0,0,0.08);">
                        <img src="@Model.Images[0]" id="mainImage" class="w-100 h-100" style="object-fit: cover; transition: transform 0.1s ease-out; transform-origin: center center;" alt="@Model.Name" />
                    </div>
                    @if (Model.Images.Count > 1)
                    {
                        <div class="thumbnail-container" style="justify-content: center;">
                            @foreach (var img in Model.Images)
                            {
                                <img src="@img" class="thumbnail" onclick="changeImage(this.src)" />
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center w-100" style="background: #f8fafc; border-radius: 16px; aspect-ratio: 1/1.1;">
                        <div class="text-center text-muted">
                            <i class="fas fa-image fa-3x mb-3"></i>
                            <p>Resim Yok</p>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Product Info -->
        <div class="col-lg-6 detail-info">
            <div>
                <span class="badge-category">@(Model.CategoryNames?.FirstOrDefault() ?? "")</span>
                <h1 class="product-title">@Model.Name</h1>
                <div class="product-code">Ürün Kodu: <strong>@Model.Code</strong></div>
                
                @if (isLoggedIn)
                {
                    <div class="price-tag" id="productPriceDisplay">@mockPrice.ToString("N0") $</div>
                }



                <div class="specs-grid">
                    <div class="spec-item">
                        <span class="spec-label">Ağırlık</span>
                        <span class="spec-value" id="productGramDisplay">@Model.Gram.ToString("N2") g</span>
                    </div>
                    <div class="spec-item">
                        <span class="spec-label">Ayar</span>
                        <select id="ayarSelect" onchange="recalculatePrice()" class="form-select" style="font-weight:700; color:#1e293b; border:none; background-color:transparent; padding:0; padding-right:24px; cursor:pointer; font-size:16px; background-position: right 0 center;">
                            @if (ViewBag.Karats != null)
                            {
                                var defaultKarat = Model.ProductMetals?.FirstOrDefault()?.MetalPurityName ?? Model.Karat;
                                foreach (var k in (IEnumerable<dynamic>)ViewBag.Karats)
                                {
                                    string milyemVal = (k.Milyem != null) ? k.Milyem.ToString(System.Globalization.CultureInfo.InvariantCulture) : "0.585";
                                    string densityVal = (k.Density != null) ? k.Density.ToString(System.Globalization.CultureInfo.InvariantCulture) : "13.4";
                                    if (defaultKarat == k.Name) {
                                        <option value="@k.Id" data-milyem="@milyemVal" data-density="@densityVal" selected data-default="true">@k.Name</option>
                                    } else {
                                        <option value="@k.Id" data-milyem="@milyemVal" data-density="@densityVal">@k.Name</option>
                                    }
                                }
                            }
                            else
                            {
                                <option data-default="true" data-milyem="0.585" data-density="13.4">@(Model.ProductMetals?.FirstOrDefault()?.MetalPurityName ?? Model.Karat ?? "Belirtilmemiş")</option>
                            }
                        </select>
                    </div>
                    <div class="spec-item">
                        <span class="spec-label">Karat</span>
                        <span class="spec-value">@Model.DiamondCarat.ToString("N2") ct</span>
                    </div>
                    <div class="spec-item">
                        <span class="spec-label">Renk</span>
                        <select id="renkSelect" class="form-select" style="font-weight:700; color:#1e293b; border:none; background-color:transparent; padding:0; padding-right:24px; cursor:pointer; font-size:16px; background-position: right 0 center;">
                            @if (ViewBag.MetalTypes != null)
                            {
                                var defaultColor = Model.ProductMetals?.FirstOrDefault()?.MetalTypeName ?? Model.ColorName;
                                foreach (var mt in (IEnumerable<dynamic>)ViewBag.MetalTypes)
                                {
                                    if (defaultColor == mt.Name) {
                                        <option value="@mt.Id" selected>@mt.Name</option>
                                    } else {
                                        <option value="@mt.Id">@mt.Name</option>
                                    }
                                }
                            }
                            else
                            {
                                <option>@(Model.ProductMetals?.FirstOrDefault()?.MetalTypeName ?? Model.ColorName ?? "Standart")</option>
                            }
                        </select>
                    </div>
                </div>

                @if (Model.ProductStones != null && Model.ProductStones.Count > 0)
                {
                    <div class="mb-4">
                        <h6 class="fw-bold text-dark mb-3"><i class="fas fa-gem me-1 text-primary"></i> Taş Bilgileri</h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered text-center align-middle" style="font-size:14px;">
                                <thead class="table-light">
                                    <tr>
                                        <th>Taş</th>
                                        <th>Renk</th>
                                        <th>Adet</th>
                                        <th>Toplam Kr.</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var s in Model.ProductStones)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@(s.StoneName ?? "Taş")</td>
                                            <td>@(s.ColorName ?? "-")</td>
                                            <td>@s.Quantity.ToString("N0")</td>
                                            <td class="text-primary fw-bold">@s.TotalCarat.ToString("N2") ct</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

                <div class="mt-4">
                    @if (isLoggedIn)
                    {
                        <button class="btn btn-dark action-button" id="addToCartBtn"
                                onclick="addToCatalogFromDetail('@Model.Code', '@(Model.CategoryNames?.FirstOrDefault() ?? "")', '@mockPrice.ToString("N0") $', '@(Model.Images.Count > 0 ? Model.Images[0] : "")', '@Model.Gram.ToString("N2", System.Globalization.CultureInfo.InvariantCulture) g')">
                            <i class="fas fa-plus"></i> Kataloğa Ekle
                        </button>
                    }
                    else
                    {
                        <a href="https://wa.me/@adminWhatsAppPhone?text=Merhaba, @Model.Code kodlu ürününüzün fiyat bilgisini öğrenebilir miyim?" target="_blank" class="btn btn-success action-button">
                            <i class="fab fa-whatsapp"></i> Fiyat Sor
                        </a>
                    }
                </div>

                <div class="mt-4 p-3" style="background:#fffbeb; border-left:4px solid #f59e0b; border-radius:0 8px 8px 0;">
                    <h6 class="fw-bold text-dark mb-1"><i class="fas fa-info-circle me-1 text-warning"></i> Açıklama</h6>
                    <p class="text-muted mb-0" style="line-height: 1.6; font-size:14px; white-space: pre-wrap;">
                        @(string.IsNullOrEmpty(Model.Description) ? "Bu ürün için henüz bir açıklama eklenmemiştir." : Model.Description)
                    </p>
                </div>

            </div>
        </div>

        <!-- Slider Section (Full Width at Bottom) -->
        <div class="col-12 p-4 p-lg-5" style="border-top: 1px solid #f1f5f9; background: #fafaf9;">
            @if(ViewBag.RelatedProducts != null && ((IEnumerable<dynamic>)ViewBag.RelatedProducts).Any())
            {
                <div class="container-fluid px-0">
                    <h4 class="fw-bold mb-4 text-center" style="color: #1e293b; font-size: 22px;"><i class="fas fa-layer-group me-2 text-primary"></i> Diğer Ürünlerimiz</h4>
                    <div class="d-flex overflow-auto pb-3 justify-content-lg-center" style="gap: 20px; scroll-snap-type: x mandatory;">
                        @foreach(var relProduct in (IEnumerable<dynamic>)ViewBag.RelatedProducts)
                        {
                            <div style="flex: 0 0 200px; scroll-snap-align: start;">
                                <div class="card h-100 border-0 shadow-sm" style="border-radius: 12px; transition: transform 0.2s;">
                                    <a href="/Home/Detail/@relProduct.Id" class="text-decoration-none">
                                        @if(relProduct.Images != null && relProduct.Images.Count > 0) {
                                            <img src="@relProduct.Images[0]" class="card-img-top" style="height: 180px; object-fit: cover; border-radius: 12px 12px 0 0;" alt="@relProduct.Name">
                                        } else {
                                            <div class="bg-light d-flex align-items-center justify-content-center" style="height: 180px; border-radius: 12px 12px 0 0;">
                                                <i class="fas fa-image text-muted fa-2x"></i>
                                            </div>
                                        }
                                        <div class="card-body p-3 text-center">
                                            <h6 class="card-title text-dark fw-bold mb-1 text-truncate" style="font-size: 15px;">@relProduct.Name</h6>
                                            <p class="text-muted small mb-0">@relProduct.Code</p>
                                        </div>
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <!-- Mock Slider for Demonstration -->
                <div class="container-fluid px-0">
                    <h4 class="fw-bold mb-4 text-center" style="color: #1e293b; font-size: 22px;"><i class="fas fa-layer-group me-2 text-primary"></i> Diğer Ürünlerimiz</h4>
                    <div class="d-flex overflow-auto pb-3 justify-content-lg-center" style="gap: 20px; scroll-snap-type: x mandatory;">
                        @for(int i=1; i<=5; i++)
                        {
                            <div style="flex: 0 0 200px; scroll-snap-align: start;">
                                <div class="card h-100 border-0 shadow-sm" style="border-radius: 12px; transition: transform 0.2s;">
                                    <a href="#" class="text-decoration-none">
                                        <div class="bg-light d-flex align-items-center justify-content-center" style="height: 180px; border-radius: 12px 12px 0 0;">
                                            <i class="fas fa-image text-muted fa-2x"></i>
                                        </div>
                                        <div class="card-body p-3 text-center">
                                            <h6 class="card-title text-dark fw-bold mb-1 text-truncate" style="font-size: 15px;">Örnek Ürün @i</h6>
                                            <p class="text-muted small mb-0">TEST-000@(i)</p>
                                        </div>
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<script>
    let liveGoldPrice = @Model.LiveGoldPrice.ToString(System.Globalization.CultureInfo.InvariantCulture);
    const backendGoldPrice = @Model.LiveGoldPrice.ToString(System.Globalization.CultureInfo.InvariantCulture);
    const basePrice = @mockPrice.ToString(System.Globalization.CultureInfo.InvariantCulture);
    const gram = @Model.Gram.ToString(System.Globalization.CultureInfo.InvariantCulture);
    const productCode = '@Model.Code';
    const productCategory = '@(Model.CategoryNames?.FirstOrDefault() ?? "")';
    const productImage = '@(Model.Images.Count > 0 ? Model.Images[0] : "")';

    document.addEventListener("DOMContentLoaded", async function() {
        try {
            const API_BASE_URL = '@apiAddress';
            const response = await fetch(`${API_BASE_URL}/api/ExchangeRate/HasAltin`);
            if(response.ok) {
                const data = await response.json();
                if(data && data.price) {
                    liveGoldPrice = data.price;
                    // Yeni kur ile hemen hesaplamayı tetikle
                    recalculatePrice();
                }
            }
        } catch(e) { console.log("Has Altın fiyatı çekilemedi", e); }
    });

    function recalculatePrice() {
        const selectElement = document.getElementById('ayarSelect');
        if (!selectElement) return;

        const defaultOption = selectElement.querySelector('option[data-default="true"]');
        const selectedOption = selectElement.options[selectElement.selectedIndex];
        
        if (!defaultOption || !selectedOption) return;

        const defaultMilyem = parseFloat(defaultOption.getAttribute('data-milyem')) || 0.585;
        const newMilyem = parseFloat(selectedOption.getAttribute('data-milyem')) || 0.585;

        const defaultDensity = parseFloat(defaultOption.getAttribute('data-density')) || 13.4;
        const newDensity = parseFloat(selectedOption.getAttribute('data-density')) || 13.4;
        
        // Calculate the new weight based on density difference
        let currentGram = gram;
        if (newDensity > 0 && defaultDensity > 0) {
            currentGram = gram * (newDensity / defaultDensity);
        }

        // Update Gram display in UI
        const gramDisplay = document.getElementById('productGramDisplay');
        if (gramDisplay) {
            gramDisplay.innerText = currentGram.toLocaleString('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' g';
        }
        
        // We need a fallback just in case both LiveGoldPrice was 0 and API failed.
        const hasPrice = liveGoldPrice > 0 ? liveGoldPrice : 150; 
        
        // 1. Veritabanındaki "CalculatedPrice"ın içindeki ESKİ kur ile olan altın maliyetini bul
        const oldGoldCost = gram * defaultMilyem * backendGoldPrice;
        
        // 2. Taş, İşçilik vb. diğer sabit maliyetleri fiyattan ayrıştır
        const fixedCosts = basePrice - oldGoldCost;
        
        // 3. YENİ çekilen anlık kur, YENİ gram ve YENİ milyem ile güncel altın maliyetini bul
        const newGoldCost = currentGram * newMilyem * hasPrice;
        
        // 4. Yeni Fiyat = Sabit Maliyetler + Güncel Altın Maliyeti
        const newPrice = fixedCosts + newGoldCost;
        
        // Format as whole number, e.g. "949 $"
        const formattedPrice = newPrice.toLocaleString('tr-TR', { maximumFractionDigits: 0 }) + ' $';
        
        // Update UI
        const priceDisplay = document.getElementById('productPriceDisplay');
        if (priceDisplay) {
            priceDisplay.innerText = formattedPrice;
        }
        
        // Update Add to Cart Button's onclick parameters to include the new calculated price and gram!
        const addToCartBtn = document.getElementById('addToCartBtn');
        if (addToCartBtn) {
            const displayGramStr = currentGram.toLocaleString('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' g';
            addToCartBtn.setAttribute('onclick', `addToCatalogFromDetail('${productCode}', '${productCategory}', '${formattedPrice}', '${productImage}', '${displayGramStr}')`);
        }
    }

    function changeImage(src) {
        document.getElementById('mainImage').src = src;
        
        // Remove active class from all thumbnails
        document.querySelectorAll('.thumbnail').forEach(t => t.classList.remove('active'));
        // Add active class to clicked
        event.target.classList.add('active');
    }

    // Image Magnifier logic
    document.addEventListener("DOMContentLoaded", function() {
        const container = document.getElementById('imageContainer');
        const img = document.getElementById('mainImage');

        if(container && img) {
            container.addEventListener('mousemove', function(e) {
                const rect = container.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                
                const xPercent = (x / rect.width) * 100;
                const yPercent = (y / rect.height) * 100;
                
                img.style.transformOrigin = `${xPercent}% ${yPercent}%`;
                img.style.transform = 'scale(2)';
            });

            container.addEventListener('mouseleave', function() {
                img.style.transformOrigin = 'center center';
                img.style.transform = 'scale(1)';
            });
        }
    });

    function addToCatalogFromDetail(code, category, price, image, gram) {
        if(!image) {
            document.getElementById('globalErrorTitle').innerText = 'Hata';
            document.getElementById('globalErrorMessage').innerText = 'Bu ürünün resmi yok, eklenemez.';
            document.querySelector('#globalErrorModal .fas').className = 'fas fa-exclamation-circle text-danger mb-3';
            new bootstrap.Modal(document.getElementById('globalErrorModal')).show();
            return;
        }

        if(typeof cart !== 'undefined') {
            // Get actual price, ayar, and renk dynamically
            var priceDisplay = document.getElementById('productPriceDisplay');
            var currentPrice = priceDisplay ? priceDisplay.innerText.trim() : price;
            
            var gramDisplay = document.getElementById('productGramDisplay');
            var currentGram = gramDisplay ? gramDisplay.innerText.trim() : gram;
            
            var ayarSelect = document.getElementById('ayarSelect');
            var ayar = ayarSelect && ayarSelect.options.length > 0 ? ayarSelect.options[ayarSelect.selectedIndex].text : '';
            
            var renkSelect = document.getElementById('renkSelect');
            var renk = renkSelect && renkSelect.options.length > 0 ? renkSelect.options[renkSelect.selectedIndex].text : '';
            
            // To allow same product with different specs, generate a unique cartId
            var cartId = code + '-' + Date.now();

            cart.push({
                id: cartId, 
                code: code, 
                image: image, 
                category: category, 
                price: currentPrice,
                ayar: ayar,
                renk: renk,
                gram: currentGram
            });
            
            if(typeof updateCartUI === 'function') updateCartUI();
            
            if(typeof updateCartUI === 'function') updateCartUI();
            
            // Butonda görsel geri bildirim ver (modal yerine)
            var btn = document.getElementById('addToCartBtn');
            if(btn) {
                var originalHtml = btn.innerHTML;
                btn.classList.remove('btn-dark');
                btn.classList.add('btn-success');
                btn.innerHTML = '<i class="fas fa-check"></i> Eklendi';
                setTimeout(function() {
                    btn.classList.remove('btn-success');
                    btn.classList.add('btn-dark');
                    btn.innerHTML = originalHtml;
                }, 1500);
            }
            
            var offcanvasEl = document.getElementById('catalogOffcanvas');
            if(offcanvasEl) {
                var offcanvas = bootstrap.Offcanvas.getInstance(offcanvasEl) || new bootstrap.Offcanvas(offcanvasEl);
                offcanvas.show();
            }
        } else {
            alert("Katalog sistemi yüklenemedi.");
        }
    }
</script>
