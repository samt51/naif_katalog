@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="dashboard-grid" style="display:grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap:24px; margin-bottom:30px;">
    <div class="card" style="border-left:4px solid var(--primary);">
        <h4 style="color:var(--text-muted); font-size:14px; margin-bottom:8px;">Toplam Ürün</h4>
        <div style="font-size:28px; font-weight:700;">1,248</div>
    </div>
    <div class="card" style="border-left:4px solid #10b981;">
        <h4 style="color:var(--text-muted); font-size:14px; margin-bottom:8px;">Kayıtlı Müşteri</h4>
        <div style="font-size:28px; font-weight:700;">86</div>
    </div>
    <div class="card" style="border-left:4px solid #f59e0b;">
        <h4 style="color:var(--text-muted); font-size:14px; margin-bottom:8px;">Kategoriler</h4>
        <div style="font-size:28px; font-weight:700;">14</div>
    </div>
    <div class="card" style="border-left:4px solid #8b5cf6;">
        <h4 style="color:var(--text-muted); font-size:14px; margin-bottom:8px;">Sistem Uyarıları</h4>
        <div style="font-size:28px; font-weight:700;">0</div>
    </div>
</div>

<div class="card">
    <h3 style="margin-bottom:20px; font-size:18px;">Son Eklenen Ürünler</h3>
    <table style="width:100%; border-collapse: collapse; text-align:left;">
        <thead>
            <tr style="border-bottom:2px solid var(--border-color);">
                <th style="padding:12px 8px; color:var(--text-muted);">Kod</th>
                <th style="padding:12px 8px; color:var(--text-muted);">Kategori</th>
                <th style="padding:12px 8px; color:var(--text-muted);">Ayar</th>
                <th style="padding:12px 8px; color:var(--text-muted);">Durum</th>
            </tr>
        </thead>
        <tbody>
            <tr style="border-bottom:1px solid var(--border-color);">
                <td style="padding:12px 8px; font-weight:500;">DGF26BL00070</td>
                <td style="padding:12px 8px;">Bileklik</td>
                <td style="padding:12px 8px;">14K</td>
                <td style="padding:12px 8px;"><span style="background:#d1fae5; color:#065f46; padding:4px 8px; border-radius:4px; font-size:12px; font-weight:600;">Aktif</span></td>
            </tr>
            <tr style="border-bottom:1px solid var(--border-color);">
                <td style="padding:12px 8px; font-weight:500;">DGF26KU00089</td>
                <td style="padding:12px 8px;">Kolye</td>
                <td style="padding:12px 8px;">14K</td>
                <td style="padding:12px 8px;"><span style="background:#d1fae5; color:#065f46; padding:4px 8px; border-radius:4px; font-size:12px; font-weight:600;">Aktif</span></td>
            </tr>
        </tbody>
    </table>
</div>
