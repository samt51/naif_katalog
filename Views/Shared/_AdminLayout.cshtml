<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Yönetim Paneli</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" />
</head>
<body>
    <div class="admin-wrapper">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <h3>KATALOG<span style="color:var(--primary);">ADMIN</span></h3>
            </div>
            <div class="sidebar-menu">
                <a href="/Admin/Dashboard" class="menu-item @(ViewContext.RouteData.Values["Action"].ToString() == "Dashboard" ? "active" : "")">
                    <i class="fas fa-home"></i> Dashboard
                </a>
                <a href="/Product/Index" class="menu-item @(ViewContext.RouteData.Values["Controller"].ToString() == "Product" ? "active" : "")">
                    <i class="fas fa-ring"></i> Ürün Yönetimi
                </a>
                <a href="/Category/Index" class="menu-item @(ViewContext.RouteData.Values["Controller"].ToString() == "Category" ? "active" : "")">
                    <i class="fas fa-list"></i> Kategoriler
                </a>
                <a href="/Admin/Customers" class="menu-item @(ViewContext.RouteData.Values["Action"].ToString() == "Customers" ? "active" : "")">
                    <i class="fas fa-users"></i> Müşteriler (Users)
                </a>
                <a href="/Admin/StoneLots" class="menu-item @(ViewContext.RouteData.Values["Action"].ToString() == "StoneLots" ? "active" : "")">
                    <i class="fas fa-gem"></i> Taş Partileri
                </a>
                <a href="/Definition/Index" class="menu-item @(ViewContext.RouteData.Values["Controller"].ToString() == "Definition" ? "active" : "")">
                    <i class="fas fa-cog"></i> Genel Tanımlamalar
                </a>
                <a href="/Admin/Logs" class="menu-item @(ViewContext.RouteData.Values["Action"].ToString() == "Logs" ? "active" : "")">
                    <i class="fas fa-history"></i> Müşteri Hareketleri
                </a>
                <a href="/Account/Logout" class="menu-item" style="margin-top:auto; border-left:none; color:#ef4444;">
                    <i class="fas fa-sign-out-alt"></i> Çıkış Yap
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <header class="top-header">
                <h1>@ViewData["Title"]</h1>
                <div class="user-profile">
                    <span>Yönetici</span>
                    <div style="width:40px;height:40px;border-radius:50%;background:var(--primary);display:flex;align-items:center;justify-content:center;color:white;font-weight:bold;">Y</div>
                </div>
            </header>
            
            <div class="content-body">
                @RenderBody()
            </div>
        </main>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</body>
</html>


